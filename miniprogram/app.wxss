page {
  min-height: 100%;
  background: #08101d url('/assets/bg-mini.jpg') no-repeat center top;
  background-size: cover;
  color: #f8fafc;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea,
picker,
scroll-view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  line-height: 1.2;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  background: rgba(4, 10, 20, 0.48);
}

.glass-card {
  background: rgba(14, 23, 42, 0.76);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(2, 8, 23, 0.28);
}

.page-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.nav-pill {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  color: #cbd5e1;
  background: rgba(30, 41, 59, 0.74);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  font-weight: 600;
}

.nav-pill--active {
  color: #ffffff;
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.34), rgba(34, 211, 238, 0.2));
  border-color: rgba(125, 211, 252, 0.3);
}

.hero-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 12rpx;
  color: #7dd3fc;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.hero-title {
  display: block;
  font-size: 42rpx;
  line-height: 1.28;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.hero-desc {
  display: block;
  color: #cbd5e1;
  line-height: 1.7;
}

.stat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  flex: 1 1 200rpx;
  min-width: 200rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.8);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stat-number {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #e0f2fe;
}

.stat-label {
  display: block;
  margin-top: 12rpx;
  color: #94a3b8;
}

.section-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
}

.section-subtitle {
  display: block;
  color: #94a3b8;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.form-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #cbd5e1;
  font-size: 24rpx;
  font-weight: 600;
}

.text-input,
.textarea-input,
.picker-input {
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(15, 23, 42, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: #f8fafc;
}

.textarea-input {
  min-height: 220rpx;
}

.picker-input--muted {
  color: #94a3b8;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-row > view {
  flex: 1;
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.primary-btn,
.secondary-btn,
.danger-btn,
.ghost-btn,
.small-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-btn {
  background: linear-gradient(135deg, #60a5fa, #8b5cf6);
  color: #ffffff;
}

.secondary-btn {
  background: rgba(59, 130, 246, 0.2);
  color: #dbeafe;
  border: 1rpx solid rgba(96, 165, 250, 0.28);
}

.danger-btn {
  background: rgba(248, 113, 113, 0.18);
  color: #fee2e2;
  border: 1rpx solid rgba(248, 113, 113, 0.24);
}

.ghost-btn {
  background: rgba(255, 255, 255, 0.08);
  color: #e2e8f0;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.small-btn {
  min-height: 64rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.status-text {
  color: #f8fafc;
  opacity: 0.78;
  line-height: 1.6;
}

.tab-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tab-chip {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  color: #cbd5e1;
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  font-weight: 600;
}

.tab-chip--active {
  background: rgba(96, 165, 250, 0.22);
  color: #ffffff;
  border-color: rgba(147, 197, 253, 0.3);
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-card,
.record-card,
.milestone-card,
.recent-card,
.overview-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.45;
}

.card-copy {
  display: block;
  color: #cbd5e1;
  line-height: 1.68;
}

.muted-text {
  color: #94a3b8;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.meta-chip,
.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #e2e8f0;
  font-size: 22rpx;
}

.date-head {
  padding: 8rpx 4rpx 4rpx;
}

.date-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(96, 165, 250, 0.2);
  color: #eff6ff;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.row-between {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.inline-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
  margin-top: 16rpx;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #60a5fa, #34d399);
}

.empty-state {
  padding: 32rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx dashed rgba(255, 255, 255, 0.16);
  color: #cbd5e1;
  line-height: 1.7;
}

.empty-title {
  display: block;
  margin-bottom: 12rpx;
  font-weight: 700;
  color: #ffffff;
}

.split-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.kv-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.kv-card {
  flex: 1 1 200rpx;
  min-width: 200rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.kv-value {
  display: block;
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.notice-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(96, 165, 250, 0.12);
  border: 1rpx solid rgba(125, 211, 252, 0.22);
  color: #e0f2fe;
  line-height: 1.7;
}
