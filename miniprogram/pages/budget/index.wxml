<view class="page-shell">
  <view class="glass-card page-nav">
    <view
      wx:for="{{navItems}}"
      wx:key="key"
      class="nav-pill {{item.active ? 'nav-pill--active' : ''}}"
      data-path="{{item.path}}"
      bindtap="handleNavTap"
    >
      {{item.label}}
    </view>
  </view>

  <view class="glass-card hero-card budget-hero">
    <text class="eyebrow">Monthly Spend</text>
    <text class="hero-title">把这个月还要花的钱，提前看清楚。</text>
    <text class="hero-desc">这里把总预算、分类预算、固定模板和当月计划项放在一起。实际消费还是继续走“消费记录”页，但你能在这里直观看到本月还剩多少可支配金额。</text>

    <view class="hero-chip-row">
      <view class="hero-chip">
        <text class="hero-chip-label">当前月份</text>
        <text class="hero-chip-value">{{monthLabel}}</text>
      </view>
      <view class="hero-chip">
        <text class="hero-chip-label">待发生</text>
        <text class="hero-chip-value">{{view.pendingItems.length}} 项</text>
      </view>
      <view class="hero-chip">
        <text class="hero-chip-label">未分配预算</text>
        <text class="hero-chip-value">{{view.summary.unallocatedBudgetText}}</text>
      </view>
    </view>
  </view>

  <view class="glass-card section-card">
    <view class="month-bar">
      <button class="ghost-btn month-btn" bindtap="goPrevMonth">上个月</button>
      <view class="month-center">
        <text class="month-label">{{monthLabel}}</text>
        <text class="month-copy">切换月份后，总览和计划设置会一起更新。</text>
      </view>
      <button class="ghost-btn month-btn" bindtap="goNextMonth">下个月</button>
    </view>

    <view class="tab-row">
      <view
        class="tab-chip {{activeView === 'overview' ? 'tab-chip--active' : ''}}"
        data-view="overview"
        bindtap="switchView"
      >
        总览
      </view>
      <view
        class="tab-chip {{activeView === 'planning' ? 'tab-chip--active' : ''}}"
        data-view="planning"
        bindtap="switchView"
      >
        计划设置
      </view>
    </view>
  </view>

  <block wx:if="{{activeView === 'overview'}}">
    <view class="stat-grid">
      <view class="stat-card">
        <text class="stat-number">{{view.summary.totalBudgetText}}</text>
        <text class="stat-label">本月总预算</text>
      </view>
      <view class="stat-card">
        <text class="stat-number">{{view.summary.actualTotalText}}</text>
        <text class="stat-label">已经花了</text>
      </view>
      <view class="stat-card">
        <text class="stat-number">{{view.summary.plannedForecastTotalText}}</text>
        <text class="stat-label">预计待花</text>
      </view>
      <view class="stat-card">
        <text class="stat-number">{{view.summary.remainingText}}</text>
        <text class="stat-label">剩余可支配</text>
      </view>
    </view>

    <view class="glass-card section-card">
      <view class="section-head">
        <view>
          <text class="section-title">分类预算对比</text>
          <text class="section-subtitle">按分类看预算、实际、待花和剩余，提前判断哪里会超支。</text>
        </view>
      </view>

      <view wx:if="{{view.compareRows.length}}" class="compare-list">
        <view wx:for="{{view.compareRows}}" wx:key="categoryId" class="compare-card">
          <view class="row-between">
            <view>
              <text class="card-title">{{item.category.icon}} {{item.category.name}}</text>
              <text class="card-copy">预算 {{item.budgetAmountText}}，已占用 {{item.usedTotalText}}</text>
            </view>
            <text class="compare-main-value">{{item.remainingText}}</text>
          </view>

          <view class="meta-row">
            <text class="meta-chip">实际 {{item.actualSpentText}}</text>
            <text class="meta-chip">待花 {{item.plannedSpentText}}</text>
            <text class="meta-chip">剩余 {{item.remainingText}}</text>
          </view>

          <view class="compare-track">
            <view class="compare-bar compare-bar--total" style="{{'width:' + item.totalWidth + '%;'}}"></view>
            <view class="compare-bar compare-bar--actual" style="{{'width:' + item.actualWidth + '%;'}}"></view>
          </view>
        </view>
      </view>

      <view wx:else class="empty-state">
        <text class="empty-title">这个月还没设置分类预算</text>
        <text>去“计划设置”里先给吃饭、住宿、BTC、娱乐这些分类加预算，这里就会开始做对比。</text>
      </view>
    </view>

    <view class="glass-card section-card">
      <view class="section-head">
        <view>
          <text class="section-title">本月待发生项目</text>
          <text class="section-subtitle">这里只显示还会继续占用本月预算的计划项。</text>
        </view>
      </view>

      <view wx:if="{{view.pendingItems.length}}" class="card-list">
        <view wx:for="{{view.pendingItems}}" wx:key="id" class="record-card">
          <view class="row-between">
            <view>
              <text class="card-title">{{item.title}}</text>
              <text class="card-copy">{{item.note || '没有补充备注'}}</text>
            </view>
            <text class="compare-main-value">{{item.amountText}}</text>
          </view>

          <view class="meta-row">
            <text class="meta-chip">{{item.category.icon}} {{item.category.name}}</text>
            <text class="meta-chip">{{item.plannedDateLabel}}</text>
            <text class="meta-chip">{{item.statusLabel}}</text>
          </view>
        </view>
      </view>

      <view wx:else class="empty-state">
        <text class="empty-title">当前没有待发生项目</text>
        <text>如果固定模板都已经发生，或者本月一次性计划已经处理完，这里会保持空白。</text>
      </view>
    </view>
  </block>

  <block wx:if="{{activeView === 'planning'}}">
    <view class="glass-card section-card">
      <view class="section-head">
        <view>
          <text class="section-title">预算设置</text>
          <text class="section-subtitle">先定本月总上限，再拆到重点分类。</text>
        </view>
      </view>

      <view class="budget-form-grid">
        <view class="budget-panel">
          <text class="field-label">本月总预算</text>
          <input class="text-input" type="digit" placeholder="例如：3000" value="{{totalBudgetInput}}" bindinput="handleTotalBudgetInput" />
          <view class="form-actions">
            <button class="primary-btn" bindtap="saveTotalBudget">保存总预算</button>
          </view>
          <text wx:if="{{budgetStatusText}}" class="status-text">{{budgetStatusText}}</text>
        </view>

        <view class="budget-panel">
          <text class="field-label">分类预算</text>
          <picker range="{{view.categories}}" range-key="displayName" bindchange="handleCategorySelect" data-form="categoryBudgetForm" data-label-field="categoryBudgetCategoryLabel">
            <view class="picker-input">{{categoryBudgetCategoryLabel}}</view>
          </picker>
          <input class="text-input" type="digit" placeholder="例如：1200" value="{{categoryBudgetForm.amount}}" data-form="categoryBudgetForm" data-field="amount" bindinput="handleFormInput" />
          <view class="form-actions">
            <button class="secondary-btn" bindtap="saveCategoryBudget">保存分类预算</button>
          </view>
          <text wx:if="{{categoryBudgetStatusText}}" class="status-text">{{categoryBudgetStatusText}}</text>
        </view>
      </view>

      <view class="notice-card">
        <text>分类预算总额 {{view.summary.categoryBudgetTotalText}}，未分配预算 {{view.summary.unallocatedBudgetText}}。</text>
      </view>

      <view wx:if="{{view.planning.categoryBudgetRows.length}}" class="budget-row-list">
        <view wx:for="{{view.planning.categoryBudgetRows}}" wx:key="categoryId" class="budget-row">
          <view>
            <text class="card-title">{{item.category.icon}} {{item.category.name}}</text>
            <text class="card-copy">预算 {{item.budgetAmountText}}，实际 {{item.actualSpentText}}，待花 {{item.plannedSpentText}}</text>
          </view>
          <view class="budget-row-actions">
            <button class="small-btn danger-btn" data-id="{{item.categoryId}}" bindtap="removeCategoryBudget">移除</button>
          </view>
        </view>
      </view>
    </view>

    <view class="glass-card section-card">
      <view class="section-head">
        <view>
          <text class="section-title">{{editingForecastId ? '编辑本月计划项' : '新增本月计划项'}}</text>
          <text class="section-subtitle">像 12 号剧本杀、住宿 50 这种一次性花销，直接记在这里。</text>
        </view>
      </view>

      <view class="form-grid">
        <view>
          <text class="field-label">项目名称</text>
          <input class="text-input" placeholder="例如：12 号剧本杀" value="{{forecastForm.title}}" data-form="forecastForm" data-field="title" bindinput="handleFormInput" />
        </view>

        <view class="form-row">
          <view>
            <text class="field-label">金额</text>
            <input class="text-input" type="digit" placeholder="356" value="{{forecastForm.amount}}" data-form="forecastForm" data-field="amount" bindinput="handleFormInput" />
          </view>
          <view>
            <text class="field-label">日期</text>
            <picker mode="date" value="{{forecastForm.plannedDate}}" bindchange="handleForecastDateChange">
              <view class="picker-input">{{forecastForm.plannedDate}}</view>
            </picker>
          </view>
        </view>

        <view>
          <text class="field-label">分类</text>
          <picker range="{{view.categories}}" range-key="displayName" bindchange="handleCategorySelect" data-form="forecastForm" data-label-field="forecastCategoryLabel">
            <view class="picker-input">{{forecastCategoryLabel}}</view>
          </picker>
        </view>

        <view>
          <text class="field-label">备注</text>
          <textarea class="textarea-input" placeholder="补充地点、同行人或原因" value="{{forecastForm.note}}" data-form="forecastForm" data-field="note" bindinput="handleFormInput"></textarea>
        </view>

        <view class="form-actions">
          <button class="primary-btn" bindtap="saveForecastItem">{{editingForecastId ? '保存修改' : '保存计划项'}}</button>
          <button wx:if="{{editingForecastId}}" class="ghost-btn" bindtap="cancelForecastEdit">取消编辑</button>
        </view>

        <text wx:if="{{forecastStatusText}}" class="status-text">{{forecastStatusText}}</text>
      </view>
    </view>

    <view class="glass-card section-card">
      <view class="section-head">
        <view>
          <text class="section-title">本月一次性计划项</text>
          <text class="section-subtitle">计划项发生后可以标记为“已发生”或“跳过”，这样它就不会继续计入待花。</text>
        </view>
      </view>

      <view wx:if="{{view.planning.oneOffItems.length}}" class="card-list">
        <view wx:for="{{view.planning.oneOffItems}}" wx:key="id" class="record-card">
          <view class="row-between">
            <view>
              <text class="card-title">{{item.title}}</text>
              <text class="card-copy">{{item.note || '没有补充备注'}}</text>
            </view>
            <text class="compare-main-value">{{item.amountText}}</text>
          </view>

          <view class="meta-row">
            <text class="meta-chip">{{item.category.icon}} {{item.category.name}}</text>
            <text class="meta-chip">{{item.plannedDateLabel}}</text>
            <text class="meta-chip">{{item.statusLabel}}</text>
          </view>

          <view class="inline-actions">
            <button wx:if="{{item.isPlanned}}" class="small-btn secondary-btn" data-id="{{item.id}}" bindtap="editForecastItem">编辑</button>
            <button wx:if="{{item.isPlanned}}" class="small-btn ghost-btn" data-id="{{item.id}}" data-status="done" bindtap="updateForecastStatus">标记已发生</button>
            <button wx:if="{{item.isPlanned}}" class="small-btn ghost-btn" data-id="{{item.id}}" data-status="skipped" bindtap="updateForecastStatus">标记跳过</button>
            <button wx:if="{{!item.isPlanned}}" class="small-btn secondary-btn" data-id="{{item.id}}" data-status="planned" bindtap="updateForecastStatus">恢复待发生</button>
            <button class="small-btn danger-btn" data-id="{{item.id}}" bindtap="removeForecastItem">删除</button>
          </view>
        </view>
      </view>

      <view wx:else class="empty-state">
        <text class="empty-title">本月还没有一次性计划项</text>
        <text>先把剧本杀、住宿、聚餐、课程或旅行计划记下来，这个月的待花就会更直观。</text>
      </view>
    </view>

    <view class="glass-card section-card">
      <view class="section-head">
        <view>
          <text class="section-title">固定模板</text>
          <text class="section-subtitle">例如每月吃饭、BTC 定投、固定住宿。模板不会自动跨月，需要你手动载入到当前月份。</text>
        </view>
        <button class="secondary-btn" bindtap="loadFixedTemplates">载入到本月</button>
      </view>

      <view class="form-grid">
        <view>
          <text class="field-label">模板名称</text>
          <input class="text-input" placeholder="例如：每月 BTC 定投" value="{{fixedTemplateForm.title}}" data-form="fixedTemplateForm" data-field="title" bindinput="handleFormInput" />
        </view>

        <view class="form-row">
          <view>
            <text class="field-label">金额</text>
            <input class="text-input" type="digit" placeholder="500" value="{{fixedTemplateForm.amount}}" data-form="fixedTemplateForm" data-field="amount" bindinput="handleFormInput" />
          </view>
          <view>
            <text class="field-label">通常几号</text>
            <input class="text-input" type="number" placeholder="15" value="{{fixedTemplateForm.recurringDay}}" data-form="fixedTemplateForm" data-field="recurringDay" bindinput="handleFormInput" />
          </view>
        </view>

        <view>
          <text class="field-label">分类</text>
          <picker range="{{view.categories}}" range-key="displayName" bindchange="handleCategorySelect" data-form="fixedTemplateForm" data-label-field="templateCategoryLabel">
            <view class="picker-input">{{templateCategoryLabel}}</view>
          </picker>
        </view>

        <view>
          <text class="field-label">备注</text>
          <textarea class="textarea-input" placeholder="例如：长期定投、餐饮预算、固定住宿" value="{{fixedTemplateForm.note}}" data-form="fixedTemplateForm" data-field="note" bindinput="handleFormInput"></textarea>
        </view>

        <view class="form-actions">
          <button class="primary-btn" bindtap="saveFixedTemplate">{{editingTemplateId ? '保存修改' : '保存模板'}}</button>
          <button wx:if="{{editingTemplateId}}" class="ghost-btn" bindtap="cancelFixedTemplateEdit">取消编辑</button>
        </view>

        <text wx:if="{{templateStatusText}}" class="status-text">{{templateStatusText}}</text>
      </view>

      <view class="split-grid budget-split">
        <view>
          <view class="mini-head">
            <text class="section-title mini-title">模板列表</text>
            <text class="section-subtitle">这里维护长期会重复出现的固定项目。</text>
          </view>

          <view wx:if="{{view.planning.fixedTemplates.length}}" class="card-list">
            <view wx:for="{{view.planning.fixedTemplates}}" wx:key="id" class="record-card">
              <view class="row-between">
                <view>
                  <text class="card-title">{{item.title}}</text>
                  <text class="card-copy">{{item.category.icon}} {{item.category.name}} · {{item.recurringLabel}}</text>
                </view>
                <text class="compare-main-value">{{item.amountText}}</text>
              </view>
              <text wx:if="{{item.note}}" class="card-copy template-note">{{item.note}}</text>
              <view class="inline-actions">
                <button class="small-btn secondary-btn" data-id="{{item.id}}" bindtap="editFixedTemplate">编辑</button>
                <button class="small-btn danger-btn" data-id="{{item.id}}" bindtap="removeFixedTemplate">删除</button>
              </view>
            </view>
          </view>

          <view wx:else class="empty-state">
            <text class="empty-title">还没有固定模板</text>
            <text>先把每月吃饭、BTC 定投、固定住宿这些常规项目建成模板。</text>
          </view>
        </view>

        <view>
          <view class="mini-head">
            <text class="section-title mini-title">本月固定项</text>
            <text class="section-subtitle">这些是模板载入后，当前月份真正会继续影响预算的固定项目。</text>
          </view>

          <view wx:if="{{view.planning.fixedItems.length}}" class="card-list">
            <view wx:for="{{view.planning.fixedItems}}" wx:key="id" class="record-card">
              <view class="row-between">
                <view>
                  <text class="card-title">{{item.title}}</text>
                  <text class="card-copy">{{item.category.icon}} {{item.category.name}} · {{item.recurringDayLabel}}</text>
                </view>
                <text class="compare-main-value">{{item.amountText}}</text>
              </view>

              <view class="meta-row">
                <text class="meta-chip">{{item.statusLabel}}</text>
                <text class="meta-chip">{{item.recurringDayLabel}}</text>
              </view>

              <view class="inline-actions">
                <button wx:if="{{item.isPlanned}}" class="small-btn ghost-btn" data-id="{{item.id}}" data-status="done" bindtap="updateForecastStatus">标记已发生</button>
                <button wx:if="{{item.isPlanned}}" class="small-btn ghost-btn" data-id="{{item.id}}" data-status="skipped" bindtap="updateForecastStatus">标记跳过</button>
                <button wx:if="{{!item.isPlanned}}" class="small-btn secondary-btn" data-id="{{item.id}}" data-status="planned" bindtap="updateForecastStatus">恢复待发生</button>
                <button class="small-btn danger-btn" data-id="{{item.id}}" bindtap="removeForecastItem">删除</button>
              </view>
            </view>
          </view>

          <view wx:else class="empty-state">
            <text class="empty-title">本月还没有固定项</text>
            <text>把模板载入到当前月份之后，这里才会出现本月固定支出。</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
