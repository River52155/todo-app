.budget-hero {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.hero-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hero-chip {
  flex: 1 1 180rpx;
  min-width: 180rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.hero-chip-label {
  display: block;
  color: #94a3b8;
  font-size: 22rpx;
}

.hero-chip-value {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #f8fafc;
}

.month-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.month-btn {
  min-height: 72rpx;
  padding: 0 24rpx;
}

.month-center {
  flex: 1;
  text-align: center;
}

.month-label {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
}

.month-copy {
  display: block;
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

.compare-list,
.budget-row-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.compare-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.compare-main-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #e0f2fe;
}

.compare-track {
  position: relative;
  width: 100%;
  height: 16rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.08);
}

.compare-bar {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  border-radius: inherit;
}

.compare-bar--total {
  background: linear-gradient(90deg, rgba(251, 191, 36, 0.9), rgba(251, 113, 133, 0.82));
}

.compare-bar--actual {
  background: linear-gradient(90deg, rgba(96, 165, 250, 0.96), rgba(34, 211, 238, 0.86));
}

.budget-form-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.budget-panel {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.budget-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.budget-row-actions {
  display: flex;
  gap: 12rpx;
}

.budget-split {
  margin-top: 24rpx;
}

.mini-head {
  margin-bottom: 16rpx;
}

.mini-title {
  font-size: 30rpx;
}

.template-note {
  margin-top: 14rpx;
}
