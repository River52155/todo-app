.trend-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.trend-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.trend-label {
  width: 72rpx;
  color: #cbd5e1;
}

.trend-bar-shell {
  flex: 1;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.trend-bar-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #60a5fa, #34d399);
}

.trend-value {
  min-width: 120rpx;
  text-align: right;
  color: #e2e8f0;
  font-size: 24rpx;
}
